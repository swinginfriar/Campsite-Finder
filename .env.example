# Copy to `.env` (docker compose reads it automatically) and tweak.
# Every value is optional — unset ones fall back to the LA defaults in config.py.

# ── Home base: where "closest" is measured from ──
CAMPSAGE_HOME_NAME=Los Angeles
CAMPSAGE_HOME_LAT=34.0522
CAMPSAGE_HOME_LNG=-118.2437

# ── Search knobs ──
CAMPSAGE_SEARCH_RADIUS_MI=150
CAMPSAGE_MAX_DISTANCE_MI=150
CAMPSAGE_MIN_RATING=4.0
CAMPSAGE_MIN_REVIEWS=4
CAMPSAGE_WINDOW_DAYS=60
CAMPSAGE_WEEKENDS_ONLY=false

# ── Scanner schedule ──
CAMPSAGE_SCAN_INTERVAL_HOURS=6
CAMPSAGE_FETCH_IMAGES=true
# CAMPSAGE_RUN_ONCE=false      # set true to scan once and exit (e.g. one-off jobs)

# ── Web server ──
# CAMPSAGE_WEB_PORT=5001       # in-container port; remap the host side in compose
